---
import '../styles/global.css';

const {
  title = 'Boom Playa',
  description = 'Escuela de beach volley en Medellin: entrenamientos, campamentos, torneos y experiencias en la arena.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script src="/i18n.js" defer></script>
  </head>
  <body>
    <slot />
  </body>
</html>
