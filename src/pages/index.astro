---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { programCards } from '../data/site.js';
---

<BaseLayout
  title="Boom Playa | Inicio"
  description="Inicio de Boom Playa: noticias, testimonios y accesos principales a entrenamientos, campamentos, torneos y juego."
>
  <SiteHeader />

  <main>
    <section class="hero">
      <ImagePlaceholder label="Foto o video principal de Boom Playa" tone="hero" />
      <div class="hero-content">
        <p class="eyebrow">Escuela de beach volley</p>
        <h1>BOOM PLAYA</h1>
        <p>
          Entrena, juega y compite en una comunidad creada alrededor de la arena,
          el progreso deportivo y la energia de playa.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/entrena/">Ver entrenamientos</a>
          <a class="button secondary" href="/contacto/">Pedir informacion</a>
        </div>
      </div>
    </section>

    <section class="notice-band" aria-label="Noticias y testimonios">
      <article>
        <span>Noticias</span>
        <strong>Inscripciones abiertas para nuevos grupos.</strong>
        <p>Estamos organizando horarios por nivel, edad y disponibilidad.</p>
      </article>
      <article>
        <span>Testimonio</span>
        <strong>"El entrenamiento me ayudo a jugar con mas confianza."</strong>
        <p>Este espacio puede rotar historias reales de jugadores y familias.</p>
      </article>
      <article>
        <span>Testimonio</span>
        <strong>"La comunidad hace que uno quiera volver a la arena."</strong>
        <p>Un segundo testimonio corto ayuda a mostrar el espiritu del club.</p>
      </article>
    </section>

    <section class="section intro">
      <p class="eyebrow">Explora Boom Playa</p>
      <h2>Cada seccion ahora vive en su propia pagina.</h2>
      <p>
        Usa el menu superior para entrar a la informacion completa de cada area:
        club, entrenamientos, campamentos, torneos, juego libre, galeria y contacto.
      </p>
    </section>

    <section class="program-grid" aria-label="Programas principales">
      {programCards.map((program) => (
        <a class="program-card" href={program.href}>
          <h3>{program.title}</h3>
          <p>{program.text}</p>
          <span>Explorar</span>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>
