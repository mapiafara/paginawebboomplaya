---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<BaseLayout
  title="Boom Playa | Contacto"
  description="Formulario de preguntas, información de contacto, mapa de ubicaciones e inicio de sesión para miembros."
>
  <SiteHeader />

  <main>
    <section class="page-hero">
      <div>
        <p class="eyebrow">Contacto</p>
        <h1>Hablemos de tu próximo entrenamiento.</h1>
        <p>
          Preguntas, información de contacto, ubicaciones y acceso para miembros
          en un solo lugar.
        </p>
      </div>
      <ImagePlaceholder label="Placeholder para mapa o ubicación" tone="sea" />
    </section>

    <section class="section contact">
      <div>
        <p class="eyebrow">Preguntas</p>
        <h2>Escríbenos.</h2>
        <p>
          Este formulario puede conectar con WhatsApp, email o una herramienta de
          registros cuando esté definida.
        </p>
      </div>
      <form>
        <label>
          Nombre
          <input type="text" name="name" autocomplete="name" />
        </label>
        <label>
          Email
          <input type="email" name="email" autocomplete="email" />
        </label>
        <label>
          Mensaje
          <textarea name="message" rows="4"></textarea>
        </label>
        <button type="submit">Enviar</button>
      </form>
    </section>

    <section class="section two-column soft">
      <article>
        <p class="eyebrow">Información</p>
        <h2>Datos de contacto</h2>
        <p>Teléfono, WhatsApp, correo, redes sociales y horarios de atención.</p>
      </article>
      <article>
        <p class="eyebrow">Ubicaciones</p>
        <h2>Mapa</h2>
        <ImagePlaceholder label="Placeholder para mapa de ubicaciones" tone="small" />
      </article>
    </section>

    <section class="section member-login">
      <div>
        <p class="eyebrow">Miembros</p>
        <h2>Iniciar sesión para miembros.</h2>
        <p>
          Opciones por definir: información personal, horarios, asistencias,
          eventos, reserva de canchas, programas físicos y cupos K-Boom.
        </p>
      </div>
      <form>
        <label>
          Usuario
          <input type="text" name="user" autocomplete="username" />
        </label>
        <label>
          Contraseña
          <input type="password" name="password" autocomplete="current-password" />
        </label>
        <button type="submit">Iniciar sesión</button>
      </form>
    </section>
  </main>
</BaseLayout>
