---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<BaseLayout
  title="Boom Playa | Compite"
  description="Calendario competitivo, torneos internos, torneos abiertos, participación externa y testimonios."
>
  <SiteHeader />

  <main>
    <section class="page-hero">
      <div>
        <p class="eyebrow">Compite</p>
        <h1>Calendario competitivo para medir el progreso.</h1>
        <p>
          Torneos, resultados, inscripciones y experiencias para quienes quieren
          probar su juego en competencia.
        </p>
      </div>
      <ImagePlaceholder label="Placeholder para competencia o premiación" tone="coral" />
    </section>

    <section class="section feature">
      <p class="eyebrow">Calendario</p>
      <h2>Próximos torneos y eventos.</h2>
      <div class="schedule-grid">
        <article>
          <span>Próximo</span>
          <h3>Torneo interno</h3>
          <p>Fecha, categorías, formato y link de inscripción.</p>
        </article>
        <article>
          <span>Abierto</span>
          <h3>Torneo invitacional</h3>
          <p>Detalles para jugadores externos y equipos invitados.</p>
        </article>
        <article>
          <span>Externo</span>
          <h3>Participación del club</h3>
          <p>Eventos donde Boom Playa participa y acompañamiento disponible.</p>
        </article>
      </div>
    </section>

    <section class="section split">
      <div>
        <p class="eyebrow">Modalidades</p>
        <h2>Torneos internos, abiertos y participación externa.</h2>
      </div>
      <div class="text-stack">
        <p>Torneos internos: descripción, categorías y resultados pasados.</p>
        <p>Torneos abiertos: inscripciones, detalles, reglas y cupos.</p>
        <p>Participación externa: historias de éxito, próximos eventos y acompañamiento.</p>
      </div>
    </section>

    <section class="section quote-band">
      <p class="eyebrow">Testimonios</p>
      <h2>"Competir me mostró cuánto había avanzado."</h2>
      <p>Espacio para testimonios de jugadores despues de torneos y eventos.</p>
    </section>
  </main>
</BaseLayout>
