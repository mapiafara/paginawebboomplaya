---
import { navItems } from '../data/site.js';

const currentPath = Astro.url.pathname;
const normalize = (href) => (href === '/' ? '/' : href.replace(/\/$/, ''));
const activePath = normalize(currentPath);
---

<header class="site-header">
  <a class="brand" href="/" aria-label="Boom Playa inicio">
    <span>BOOM</span>
    <span>PLAYA</span>
  </a>
  <nav aria-label="Principal">
    {navItems.map((item) => {
      const isActive = normalize(item.href) === activePath;
      const hasActiveChild = item.children?.some((child) => normalize(child.href) === activePath);

      if (item.children) {
        return (
          <div class:list={['nav-dropdown', { active: isActive || hasActiveChild }]}>
            <a href={item.href} aria-haspopup="true" aria-expanded="false">
              {item.label}
            </a>
            <div class="nav-dropdown-menu" aria-label={item.label}>
              {item.children.map((child) => (
                <a class:list={{ active: normalize(child.href) === activePath }} href={child.href}>
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        );
      }

      return <a class:list={{ active: isActive }} href={item.href}>{item.label}</a>;
    })}
  </nav>
  <div class="header-tools">
    <button
      class="language-toggle"
      type="button"
      data-language-toggle
      data-i18n-ignore
      aria-label="Switch language to English"
    >
      EN
    </button>
    <a class="header-action" href="/entrena/#unete">Unete</a>
  </div>
</header>
